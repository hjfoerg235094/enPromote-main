# 服务器配置
PORT=3000
HOST=localhost

# 数据库（MongoDB）
DB_URL=mongodb://localhost:27017/EnglishMastery

# Session 存储（可与 DB_URL 相同或使用独立数据库）
MONGO_URL=mongodb://localhost:27017/session

# Session 密钥（生产环境务必使用强随机字符串）
SESSION_SECRET=your-super-secret-key-change-in-production

# 外网代理（可选，用于访问外部 API）
PROXY_HOST=127.0.0.1
PROXY_PORT=7897

# AI API（DeepSeek 等）
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=sk-your-api-key-here

# 科大讯飞口语评测配置
# 请从科大讯飞开放平台获取这些密钥
# 访问 https://www.xfyun.cn/ 注册账号并创建应用
XUNFEI_APP_ID=your_app_id_here
XUNFEI_API_KEY=your_api_key_here
XUNFEI_API_SECRET=your_api_secret_here
